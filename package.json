{
  "name": "bolt-for-mobile",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate" : "cd ./packages/db && pnpm exec prisma migrate dev && cd ../../",
    "db:generate" : "cd ./packages/db && pnpm exec prisma generate && cd ../../",
    "worker" : "cd ./apps/worker && pnpm run dev",
    "ws-relayer" : "cd ./apps/ws-relayer && pnpm run dev"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/express": "^5.0.5",
    "express": "^5.1.0"
  }
}
